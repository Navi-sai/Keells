package com.KeellsOrder.KeellsOrder.service;

import java.util.List;

import org.springframework.stereotype.Service;
import org.springframework.web.client.RestTemplate;
import com.KeellsOrder.KeellsOrder.dto.ItemsRequestDTO;
import com.KeellsOrder.KeellsOrder.dto.OrderRequestDTO;
import com.KeellsOrder.KeellsOrder.dto.ProductResponseDTO;
import com.KeellsOrder.KeellsOrder.exception.NotAvailableException;
import com.KeellsOrder.KeellsOrder.httpClient.HttpClient;

@Service
public class OrderService {
	
	private final HttpClient httpClient;
	
	public OrderService(HttpClient httpClient) {
		this.httpClient = httpClient;
	}
	
	//orderRequestDTO contains
	// orderBy
	// productId
	// productName
	// quantity
	
	public void createOrder(OrderRequestDTO orderRequestDTO) {
		List<ItemsRequestDTO> orderItems = orderRequestDTO.getItemsRequestDto();
				for (ItemsRequestDTO orderItem : orderItems) {
					ProductResponseDTO product = httpClient.getProductById(orderItem.getProductId());
					
					if (product.getQuantity() < orderItem.getQuantity()) {
						throw new NotAvailableException("Product Out Of Stock : " + orderItem.getProductName() + "Available Quantity in the inventory is : " + product.getQuantity());
					}
					 
				}
		
		
	}

}
